<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#16213E"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- left border  -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#7B61FF"/>

        <!-- event title -->
        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <!-- date and time-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvEventDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Date"
                android:textColor="#7B61FF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvEventTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐 Time"
                android:textColor="#7B61FF"
                android:textSize="13sp"
                android:layout_marginStart="16dp"/>

        </LinearLayout>

        <!-- location -->
        <TextView
            android:id="@+id/tvEventLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Location"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

        <!-- description -->
        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"/>

        <!-- divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A4A"
            android:layout_marginTop="12dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvAttendeeCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 attending"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnRsvp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RSVP"
                android:textSize="12sp"
                android:backgroundTint="#7B61FF"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>