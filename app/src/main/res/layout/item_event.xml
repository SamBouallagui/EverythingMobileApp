<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Left accent border -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#7B61FF"/>

        <!-- Event Title -->
        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Author Name -->
        <TextView
            android:id="@+id/tvEventAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Created by Author"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:alpha="0.8"/>

        <!-- Date and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvEventDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Date"
                android:textColor="#7B61FF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvEventTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐 Time"
                android:textColor="#7B61FF"
                android:textSize="13sp"
                android:layout_marginStart="16dp"/>

        </LinearLayout>

        <!-- Location -->
        <TextView
            android:id="@+id/tvEventLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Location"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="12dp"/>

        <!-- Description -->
        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="#4B5563"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="12dp"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp"/>

        <!-- Attendance Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvAttendeeCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 attending"
                android:textColor="#6B7280"
                android:textSize="12sp"/>

            <ImageButton
                android:id="@+id/btnDeleteEvent"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"
                android:contentDescription="Delete event"
                android:tint="#FF6B6B"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnRsvp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="RSVP"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7B61FF"
                app:cornerRadius="18dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>